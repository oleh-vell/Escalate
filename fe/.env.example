# All of these must also be set in the Vercel project (Settings → Environment Variables).

# Telegram bot — see SETUP_TELEGRAM.md
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Kill switch: "true" makes POST /api/ask return 503 "Oleh is napping"
PAUSED=false

# Display name of the human in the loop (landing copy). Defaults to "oleh".
NEXT_PUBLIC_ESCALATE_HUMAN=oleh

# Upstash Redis — rate-limit counters ONLY (no question data)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Neon Postgres — pooled connection string (questions/answers live here)
DATABASE_URL=

# CLI default backend (also a TODO placeholder in cli/escalate/config.py)
ESCALATE_API_URL=
